clear; clc; clf;   
// clear = removes variables from memory
// clc = clears command window
// clf = clears current figure window

hc = 197.3;         
// ħc in MeV·fm (useful constant in nuclear physics)

m = 940;  
// Particle mass in MeV (approx proton mass)

k = 100; 
// Quadratic potential coefficient

b = 30;
// Cubic potential coefficient

A = (hc^2) / (2*m);
// Constant factor in kinetic energy term: ħ² / (2m)

rmax = 8;      
// Maximum radial distance (fm)

N = 500;       
// Number of grid points

h = rmax / (N+1);  
// Step size of spatial grid

r = (1:N)' * h; 
// Radial coordinate vector (column vector)

v = k*r.^2/2 + b*r.^3/3;
// Potential energy V(r) = (k/2)r² + (b/3)r³

H = zeros(N,N);
// Initialize Hamiltonian matrix (NxN)

for i = 1:N
    
    H(i,i) = 2*A/(h^2) + v(i);
    // Diagonal elements:
    // kinetic term (finite difference) + potential
    
    if i > 1 then 
        H(i,i-1) = -A/(h^2);
        // Left off-diagonal (kinetic coupling)
    end
    
    if i < N then 
        H(i,i+1) = -A/(h^2);
        // Right off-diagonal (kinetic coupling)
    end
   
end

[psi, E] = spec(H);
// Compute eigenvalues (E) and eigenvectors (psi)

Evalues = diag(E); 
// Extract eigenvalues into a vector

E0 = min(Evalues); 
// Find ground state energy (lowest eigenvalue)

for i = 1:N
    if Evalues(i) == E0 then
        psi0 = psi(:,i);
        // Select eigenvector corresponding to lowest energy
        break
    end
end
 
norm = sqrt(sum(psi0.^2) * h); 
// Compute normalization factor using numerical integration

psi0 = psi0 / norm; 
// Normalize wavefunction

disp("Ground state energy = " + string(E0) + " eV"); 
// Display ground state energy

plot(r, abs(psi0));
// Plot absolute value of ground state wavefunction

xgrid(1,1,1);
// Turn grid on

xlabel("r");
// Label x-axis

ylabel("ψ(r)");
// Label y-axis